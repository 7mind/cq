cq.toml

.claude/
# direnv
.direnv/

# nix
result
result-*

# bun / node
node_modules/
.cache/
bun.lockb.tmp
*.log

# build output
dist/
build/
.next/
.vite/
.parcel-cache/
*.tsbuildinfo

# D68: prevent misplaced compiled output from being re-committed under package src/
nix/pkg/cq-ledgers/packages/*/src/**/*.js
nix/pkg/cq-ledgers/packages/*/src/**/*.d.ts
nix/pkg/cq-ledgers/packages/*/src/**/*.d.ts.map

# editor
.vscode/
.idea/
*.swp
*~
.DS_Store

# cq runtime
var/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# @cq/ledger per-cwd lockfiles + backups (the ledger files themselves are tracked)
docs/.locks/
# `cq reset` moves the bootstrap files here (timestamped) before regenerating.
docs/.ledger-backup/
# per-cwd runtime ledger registry — regenerated on connect, never tracked (fix D1).
docs/ledgers.yaml

# scratch
/debug/
**/debug/

# CodeGraph local index (per-machine)
.codegraph/
docs/.backup/

# cq git-object ledger backend (managed) — do not edit
docs/*.md
docs/ledgers.yaml
docs/.locks/
